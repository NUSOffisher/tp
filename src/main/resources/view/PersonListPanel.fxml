<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <TableView fx:id="personTableView" VBox.vgrow="ALWAYS">
    <columns>
      <TableColumn fx:id="idColumn" text="ID" prefWidth="30" resizable="false" />
      <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" />
      <TableColumn fx:id="roleColumn" text="Role" prefWidth="150" />
      <TableColumn fx:id="ratingColumn" text="Rating" prefWidth="80" />
      <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
      <TableColumn fx:id="contactColumn" text="Contact" prefWidth="120" />
      <TableColumn fx:id="emailColumn" text="Email" prefWidth="150" />
      <TableColumn fx:id="referralColumn" text="Referral Satus" prefWidth="80" />
    </columns>
    <columnResizePolicy>
      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
    </columnResizePolicy>
  </TableView>
</VBox>
